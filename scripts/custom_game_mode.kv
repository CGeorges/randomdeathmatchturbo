// Turbo Random Deathmatch - Game Mode Settings
// Combines Random Deathmatch hero swapping with Turbo pacing

"GameMode"
{
    "base_game_mode"            "1"         // Standard Dota map
    "map"                       "dota"

    // --------------------------------------------------
    // Team / Player config
    // --------------------------------------------------
    "team_count"                "2"
    "players_per_team"          "5"
    "hero_selection_mode"       "1"         // All Random (server assigns)

    // --------------------------------------------------
    // Turbo-style economy
    // --------------------------------------------------
    "gold_per_tick"             "2"         // Doubled passive gold (vanilla = 1)
    "gold_tick_time"            "0.6"       // Tick every 0.6s (vanilla = 0.6, but 2x gold)
    "starting_gold"             "750"       // Extra starting gold
    "kill_gold_multiplier"      "1.0"       // Keep kill gold normal
    "custom_gold_bonus"         "0"

    // --------------------------------------------------
    // Turbo-style XP
    // --------------------------------------------------
    "xp_multiplier"             "2.0"       // Double XP globally

    // --------------------------------------------------
    // Building / creep tweaks (Turbo-like)
    // --------------------------------------------------
    "tower_damage_multiplier"   "1.0"
    "creep_power_scale"         "1.0"

    // --------------------------------------------------
    // Respawn
    // --------------------------------------------------
    "fixed_respawn_time"        "-1"        // Use Lua-controlled respawn
    "respawn_time_multiplier"   "0.5"       // Halved base respawn (further adjusted in Lua)

    // --------------------------------------------------
    // Random Deathmatch lives
    // --------------------------------------------------
    // Managed entirely in Lua (default: unlimited swaps, you lose
    // when your Ancient falls, same as official RDM)
    // --------------------------------------------------

    // --------------------------------------------------
    // TP Scroll (Turbo gives free TPs)
    // --------------------------------------------------
    // Handled in Lua: grant free TP on spawn/respawn

    // --------------------------------------------------
    // Draft
    // --------------------------------------------------
    "hero_pool"                 "all"       // Full hero pool
    "allow_duplicate_heroes"    "0"         // No dupes in the same game
}

{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "../../scripts/vscripts",
    "target": "ESNext",
    "lib": ["ESNext"],
    "types": ["@moddota/dota-lua-types"],
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "declaration": false
  },
  "tstl": {
    "luaTarget": "JIT",
    "sourceMapTraceback": false
  },
  "include": ["./**/*.ts", "../common/**/*.d.ts"]
}
